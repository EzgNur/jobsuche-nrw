# Google Places API (isteğe bağlı, ücretli kota)
# https://console.cloud.google.com/ -> APIs -> Places API
GOOGLE_PLACES_API_KEY=your_api_key_here

# Yelp Fusion API (isteğe bağlı, ücretsiz kota: günde 5000 istek)
# https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=your_yelp_api_key_here

# OpenRegister API (isteğe bağlı, HRB sütununu otomatik doldurmak için; 50 istek/ay ücretsiz)
# https://openregister.de/keys
OPENREGISTER_API_KEY=your_api_key_here
